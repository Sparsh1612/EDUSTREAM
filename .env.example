# ===========================
# EduStream Environment Config
# ===========================

# Backend
BACKEND_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database - MongoDB
MONGODB_URI=mongodb://mongo:27017/edustream
MONGODB_USER=admin
MONGODB_PASSWORD=admin123

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION=30d

# RabbitMQ Message Queue
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_QUEUE_ENCODING=encoding.queue
RABBITMQ_QUEUE_ANALYTICS=analytics.queue

# FFmpeg Encoding
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_TEMP_DIR=/tmp/edustream/videos
ENCODED_OUTPUT_DIR=/data/encoded-videos
MAX_CONCURRENT_ENCODING_JOBS=3

# AWS S3 / Object Storage (if using DynamoDB)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=edustream-videos
S3_ENDPOINT=http://localhost:9000

# Streaming
STREAMING_QUALITY_LEVELS=240,360,480,720
HLS_SEGMENT_DURATION=6
HLS_PLAYLIST_SIZE=10

# Frontend
REACT_APP_API_BASE_URL=http://localhost:3000/api
REACT_APP_WS_URL=ws://localhost:3000/ws

# Analytics & Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Security
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Feature Flags
FEATURE_OFFLINE_SYNC=true
FEATURE_ANALYTICS=true
FEATURE_ADAPTIVE_BITRATE=true
